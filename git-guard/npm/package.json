{
  "name": "git-guard",
  "version": "1.0.0",
  "description": "Lightweight Git safety guard — blocks unsafe git pull commands",
  "type": "module",
  "bin": {
    "git-guard": "./cli.js"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "preuninstall": "node scripts/preuninstall.js"
  },
  "files": [
    "cli.js",
    "scripts/",
    "wrappers/"
  ],
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "git",
    "guard",
    "pull",
    "safety",
    "deploy",
    "staging"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/msulaimanmisri/sulaiman-setup/tree/main/git-guard"
  },
  "author": "Sulaiman Misri <saya@sulaimanmisri.com>"
}